# MiniCeliq backend — environment variables (README §11).
# Every integration is OPTIONAL: the app boots and serves /api/health with none
# of these set. Each feature degrades gracefully (503 / in-memory / disabled
# cron) until its keys are provided. Placeholders only — NO real secrets here.

# ---- Server ----
PORT=4000
NODE_ENV=development

# ---- Supabase (own, NEW project — NOT Celiq's) ----
# News cache, AI-summary cache, indexed events, free-tier quota. If unset, the
# backend falls back to in-memory equivalents (single-instance, reset on restart).
# Tables expected: news_cache, news_summaries, summary_views, subscribed_events.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ---- AI summaries (OpenRouter via Vercel AI SDK) ----
# Without OPENROUTER_API_KEY, POST /api/news/summarize returns 503.
OPENROUTER_API_KEY=
LLM_PRIMARY_MODEL=anthropic/claude-haiku-4.5
LLM_FALLBACK_MODEL=openai/gpt-4o-mini

# ---- News source (free RSS — no API key) ----
# Comma-separated feed URLs. Defaults to CoinDesk + Cointelegraph + Decrypt when
# unset. Set to "" to force the in-memory mock feed (no network).
NEWS_RSS_FEEDS=https://www.coindesk.com/arc/outboundfeeds/rss/,https://cointelegraph.com/rss,https://decrypt.co/feed

# ---- On-chain (Celo) ----
# CELO_CHAIN: celo (mainnet, 42220) | celoSepolia (testnet, 11142220)
CELO_CHAIN=celo
# Mainnet forno: https://forno.celo.org
# Sepolia forno: https://forno.celo-sepolia.celo-testnet.org
CELO_RPC=https://forno.celo.org
# Deployed NewsSubscription proxy address. Without this, on-chain reads 503 and
# the summary gate falls back to free-quota-only (no premium override).
# EIP-55 trap: store lowercase or a valid checksum — a hand-recased address breaks viem.
SUBSCRIPTION_CONTRACT_ADDRESS=

# ---- Free-tier summary quota (server read-gate, README §7/§16) ----
SUMMARY_FREE_DAILY_LIMIT=3

# ---- CORS ----
# The MiniCeliq frontend origin. Defaults to http://localhost:3000 when unset.
FRONTEND_URL=

# ---- Cron kill-switches ----
ENABLE_NEWS_INGEST=true
NEWS_INGEST_INTERVAL_MINUTES=5
ENABLE_EVENT_INDEXER=true
EVENT_INDEXER_INTERVAL_MINUTES=5
# Set to the contract deploy block so the indexer doesn't sweep from genesis.
EVENT_INDEXER_FROM_BLOCK=0

# (optional) Session pooler URI for psql migrations: Settings -> Database -> Connection string -> Session pooler.
# SUPABASE_DB_POOLER_URL=postgresql://postgres.<ref>:<db-password>@aws-1-<region>.pooler.supabase.com:5432/postgres
